			y: 0.0d
		}
		{
			dependencies: ["1EF771A80F0460CF"]
			description: ["在能看见天空的地方使用望远镜，选中视野里的星球并按住即可打印一张天文观测记录。打印记录需要消耗纸；同一目标星球、同一观测来源、同一天的记录不能重复写入同一本星图。"]
			id: "49759BA2FFD9ED2D"
			subtitle: "打印一张天文观测记录"
			tasks: [{
				id: "361B8B8E75482FFF"
				item: "northstar:astronomical_reading"
				type: "item"
			}]
			x: 2.0d
			y: -1.0d
		}
		{
			dependencies: [
				"49759BA2FFD9ED2D"
				"5D413834648E277E"
			]
			description: [
				"火箭核心只接受星图或返程票。"
				""
				"每张天文观测记录默认提供1点科研点数。同一来源的跨天重复记录会按0.9、0.81……递减；从不同星球观测同一目标，则第一张都按完整1点计算。"
				""
				"当前数据中：地球需要1点，月球需要2点，火星需要5点，金星和水星各需要6点。星球达标后，该星球的轨道和地表会一起解锁；月球目前只有地表，没有轨道维度。"
			]
			hide_dependency_lines: true
			icon: "northstar:space_atlas"
			id: "6C6B2505ED53D1F2"
			subtitle: "轨道和地表由同一份星图科研点解锁"
