		{
			dependencies: ["1EF771A80F0460CF"]
			description: ["把星图和天文观测记录放入天文台，可以把记录中的科研点数写入星图。星图内某个星球的科研点数达到要求后，火箭核心会同时显示该星球已注册的轨道和地表目的地。"]
			id: "5D413834648E277E"
			subtitle: "把观测记录写入星图"
			tasks: [{
				id: "43CDABE68393929D"
