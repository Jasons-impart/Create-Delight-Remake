# Default: ignore everything at the repo root.
/*

# Root files we intentionally version.
!/.gitignore
!/.clientonlymodlist
!/.hmclversion.cfg
!/.options.txt
!/.packwizignore
!/.serveronlymodlist
!/DevGuide.md
!/LICENSE
!/README.md
!/client_jvm_args.example.txt
!/donate_list.json
!/icon.png
!/server-icon.png
!/index.toml
!/pack.toml
!/start.bat
!/start.sh
!/sync-packwiz-assets.bat
!/update-packwiz-meta.bat
!/variables.txt
!/variables.nix.txt

# Root directories that manage their own allowlists.
!/.agents/
!/.codex/
!/.github/
!/PCL/
!/config/
!/defaultconfigs/
!/docs/
!/hotai/
!/kubejs/
!/ldlib/
!/minemenu/
!/mods/
!/packwiz-files/
!/resourcepacks/
!/schematics/
!/scripts/
!/shaderpacks/
!/tacz/

# Agent knowledge base (compatible with OpenCode + Codex)
!/AGENTS.md
!/lessons-learned.md
